# Telegram MTProto (user session) — get api_id/api_hash from https://my.telegram.org
TELEGRAM_VIXAL_AI_BOT_USERNAME=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+10000000000
TELEGRAM_SESSION=vixal_auto.session

# copytele (copyparty) destination — use the LAN origin, not the Cloudflare URL.
# Results land in <base>/image/ and <base>/video/. Must end with a slash.
COPYTELE_UPLOAD_URL=http://10.1.1.99:11117/vixal/
COPYTELE_PW=
OVERWRITE=false

DOWNLOAD_DIR=/tmp/vixal_auto
HOST=0.0.0.0
PORT=8090
